# Supabase (use your project values — never commit real secrets)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Payment webhooks (server-only). Required in production for POST /api/webhooks/* to update billing.
# Square: subscription signature key from Square Developer Dashboard.
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Alias read by the Square route if SQUARE_WEBHOOK_SIGNATURE_KEY is unset.
SQUARE_WEBHOOK_SECRET=
# Optional — OAuth / future Square app flows.
SQUARE_APP_ID=

# Stripe: Dashboard → Webhooks → Signing secret (starts with whsec_).
STRIPE_WEBHOOK_SIGNING_SECRET=
# Alias read by the Stripe route if STRIPE_WEBHOOK_SIGNING_SECRET is unset.
STRIPE_WEBHOOK_SECRET=

# App (local: http://localhost:3000; Vercel Preview/Production: your deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
